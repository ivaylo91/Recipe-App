{
  "expo": {
    "name": "Вкусни Рецепти",
    "slug": "vkusni-recepti",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a0d04"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vkusnirecepti.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a0d04"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.vkusnirecepti.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ],
    "scheme": "vkusnirecepti",
    "extra": {
      "eas": {
        "projectId": "9bbd4b84-77e7-4b05-b127-6d086fb6f64e"
      }
    },
    "owner": "ivaylo_penev"
  }
}
